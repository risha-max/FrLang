definir fonction plus_court_chemin(Graphe g, Mots depart, Mots arrivee) {
    soit nombre introuvable = 0 - 1;
    soit Mots courant = nouveau Mots("");
    soit Mots voisin = nouveau Mots("");
    soit nombre d = 0;
    soit Rangee voisins = nouveau Rangee();
    si depart.equals(arrivee) {
        retourne 0;
    }
    si g.contient_sommet(depart) {
        si g.contient_sommet(arrivee) {
            soit File noeuds = nouveau File();
            soit File distances = nouveau File();
            soit Rangee visites = nouveau Rangee();

            noeuds.enfiler(depart);
            distances.enfiler(0);
            visites.ajouter(depart);

            tantque noeuds.taille() > 0 {
                courant = noeuds.defiler();
                d = distances.defiler();
                voisins = g.voisins(courant);
                pourchaque i dans range(voisins.taille()) {
                    voisin = nouveau Mots(voisins.element(i));
                    si ajouter_si_nouveau(visites, voisin) {
                        si voisin.equals(arrivee) {
                            retourne d + 1;
                        }
                        noeuds.enfiler(voisin);
                        distances.enfiler(d + 1);
                    }
                }
            }
        }
    }
    retourne introuvable;
} retourne nombre

